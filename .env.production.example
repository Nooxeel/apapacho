# Variables de entorno de PRODUCCIÓN para Vercel
# Copiar al dashboard de Vercel → Settings → Environment Variables
# NUNCA committear valores reales. Usar placeholders aquí.

# ==================== Backend API ====================
# URL base de la API del backend (Railway). Incluye /api.
# Ejemplo: https://apapacho-backend-production.up.railway.app/api
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND-URL.up.railway.app/api

# ==================== Observabilidad — Sentry ====================
# DSN del proyecto Next.js en Sentry. OBLIGATORIO en producción para
# capturar errores del cliente y del servidor (SSR / Edge).
# Crear proyecto en https://sentry.io → Projects → New Project → Next.js
# SLA <72h (Ley 21.719) requiere Sentry activo con alertas.
NEXT_PUBLIC_SENTRY_DSN=https://YOUR-KEY@oXXXXXX.ingest.sentry.io/XXXXXXX

# Org + project slugs de Sentry (solo se usan en BUILD-TIME para
# subir source maps; no expuestos al cliente).
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# Auth token de Sentry con scope `project:releases`.
# Settings → Auth Tokens en sentry.io.
# REQUERIDO en CI/CD para subir source maps (stacks legibles en Sentry).
# Si está vacío, el build funciona pero los stacks quedan minificados.
# NUNCA usar en NEXT_PUBLIC_*.
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ==================== Auth hardening — Cloudflare Turnstile ====================
# Site Key pública de Cloudflare Turnstile (CAPTCHA gratuito).
# 1) Crear cuenta en https://dash.cloudflare.com/?to=/:account/turnstile
# 2) "Add site" → widget "Managed" → copiar Site Key.
# 3) La Secret Key va en el BACKEND (TURNSTILE_SECRET_KEY); aquí solo la pública.
# Si está vacía, el widget no se renderiza y el backend hace graceful pass con warning.
NEXT_PUBLIC_TURNSTILE_SITEKEY=0x4AAAAAAAAAAxxxxxxxxxxxxxxxx

# ==================== Pagos — Flow ====================
# Controla si el selector de pasarela muestra Flow como opción.
# Mantener 'false' hasta que el backend tenga FLOW_API_KEY + FLOW_SECRET_KEY cargados.
# El flag desacopla el deploy del frontend del estado de credenciales del backend.
NEXT_PUBLIC_FLOW_ENABLED=false
