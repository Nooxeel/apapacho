# Production Environment Variables for Vercel
# Copy these to Vercel dashboard → Settings → Environment Variables

# Backend API URL — debe usar el subdominio same-site api.appapacho.cl para
# que las cookies de sesión sean first-party (frontend appapacho.cl +
# backend api.appapacho.cl comparten el dominio registrable .appapacho.cl).
# Sin esto, los navegadores bloquean la cookie como third-party y la sesión
# se pierde en cada recarga completa.
# El valor real se configura en Vercel; NO hardcodear en el código.
NEXT_PUBLIC_API_URL=https://api.appapacho.cl/api
