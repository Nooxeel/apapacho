# API URL del backend (Railway te dará esta URL después del deploy)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Site URL (for metadata, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://appapacho.cl

# Google OAuth Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==================== Ley 21.719 — P1.3 Observabilidad (Sentry) ====================
# DSN del proyecto Next.js en Sentry. Si está vacío, todo el SDK queda en
# modo no-op (no warns, no crashes). Crear proyecto en https://sentry.io.
# NUNCA committear DSNs reales.
NEXT_PUBLIC_SENTRY_DSN=

# Org + project slugs para upload de source maps + dashboards. Solo se usan
# en BUILD-TIME (no expuestos al cliente).
SENTRY_ORG=
SENTRY_PROJECT=

# Auth token con scope `project:releases` (Settings → Auth Tokens en Sentry).
# REQUERIDO sólo en CI/CD para subir source maps. Si está vacío, el build
# funciona pero los stacks en Sentry quedan minificados.
# NUNCA exponerlo en NEXT_PUBLIC_*.
SENTRY_AUTH_TOKEN=
